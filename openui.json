      "id": "scopes",
      "type": "Scopes",
      "attrs": {
        "title": "Scopes",
        "purpose": "The `scopes` folder is the hierarchical source for OpenUI scope objects. Each top-level folder is a scope, and each child object is either another scope folder or a snake_case `*.scope.md` leaf file.",
